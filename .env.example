# =============================================
# LukeAPP v4 — Variables de entorno (ejemplo)
# Copiar a .env y completar con los valores reales
# NUNCA commitear .env con valores reales
# =============================================

# --- Supabase (self-hosted en lukeserver) ---
SUPABASE_URL=https://api.lukeapp.cl
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Conexión directa a Postgres (para ETL y migraciones)
DATABASE_URL=postgresql://postgres:PASSWORD@db.lukeapp.cl:5432/postgres

# --- Aplicaciones ---
VITE_SUPABASE_URL=https://api.lukeapp.cl
VITE_SUPABASE_ANON_KEY=

# --- PowerSync (F2.x) ---
POWERSYNC_URL=
POWERSYNC_DEV_TOKEN=

# --- ETL ---
ETL_SOURCE_PATH=./etl/data/
ETL_DRY_RUN=true
